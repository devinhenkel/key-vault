# ---- Server ----
PORT=3001
NODE_ENV=development

# PostgreSQL connection string
# For local dev: postgresql://keycatalog:keycatalog_dev@localhost:5433/keycatalog?schema=public
# For Docker: set automatically by docker-compose.yml
DATABASE_URL="postgresql://keycatalog:keycatalog_dev@localhost:5433/keycatalog?schema=public"

# Encryption secret for API key values at rest.
# Generate with: openssl rand -base64 32
# WARNING: Changing this will make existing encrypted keys unreadable.
ENCRYPTION_SECRET="change-me-to-a-real-secret"

# ---- Database (used by docker-compose) ----
POSTGRES_DB=keycatalog
POSTGRES_USER=keycatalog
POSTGRES_PASSWORD=keycatalog_dev

# ---- Frontend ----
VITE_API_URL=http://localhost:3001